<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   ExtensionBundleId="com.phygital.studio.ae"
                   ExtensionBundleVersion="0.0.1"
                   Version="10.0">
  <ExtensionList>
    <Extension Id="com.phygital.studio.ae.panel" Version="0.0.1" />
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <Host Name="AEFT" Version="[23.0,99.9]" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="11.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.phygital.studio.ae.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./client/index.html</MainPath>
          <ScriptPath>./host/insert_media.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--mixed-context</Parameter>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--disable-application-cache</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Phygital Studio</Menu>
          <Geometry>
            <Size>
              <Height>720</Height>
              <Width>420</Width>
            </Size>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
